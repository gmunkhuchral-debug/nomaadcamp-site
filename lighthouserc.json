{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "color-contrast": ["error", { "minScore": 0.9 }],
        "heading-order": ["error", { "minScore": 0.9 }],
        "image-delivery-insight": "off",
        "network-dependency-tree-insight": "off",
        "total-byte-weight": ["warn", { "maxNumericValue": 3500000 }],
        "uses-responsive-images": "off",
        "modern-image-formats": "off",
        "render-blocking-insight": "off",
        "render-blocking-resources": "off",
        "first-contentful-paint": ["warn", { "maxNumericValue": 2800 }],
        "interactive": ["warn", { "maxNumericValue": 4500 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
